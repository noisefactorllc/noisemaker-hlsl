{
  "name": "Flow",
  "namespace": "points",
  "func": "flow",
  "tags": ["sim"],
  "description": "Agent-based luminosity flow field with behaviors",
  "paramAliases": {},
  "globals": {
    "stateSize": {
      "type": "int",
      "default": 256,
      "uniform": "stateSize",
      "ui": { "control": false },
      "_role": "Sizing-only (state texture edge). Inherited from pointsEmit; NOT read by the shader (the agent shader derives state dims from the bound state texture). Used by resolveDimension via the {param:'stateSize'} texture specs below."
    },
    "behavior": {
      "type": "int",
      "default": 1,
      "uniform": "behavior",
      "choices": {
        "none": 0,
        "obedient": 1,
        "crosshatch": 2,
        "unruly": 3,
        "chaotic": 4,
        "randomMix": 5,
        "meandering": 10
      },
      "ui": { "label": "behavior", "control": "dropdown", "category": "agents" }
    },
    "stride": {
      "type": "float",
      "default": 10,
      "uniform": "stride",
      "min": 1,
      "max": 1000,
      "step": 1,
      "ui": { "label": "stride", "control": "slider", "category": "agents" }
    },
    "strideDeviation": {
      "type": "float",
      "default": 0.05,
      "uniform": "strideDeviation",
      "min": 0,
      "max": 0.5,
      "step": 0.01,
      "ui": { "label": "deviation", "control": "slider", "category": "agents" }
    },
    "kink": {
      "type": "float",
      "default": 1,
      "uniform": "kink",
      "min": 0,
      "max": 10,
      "step": 0.1,
      "ui": { "label": "kink", "control": "slider", "category": "agents" }
    },
    "quantize": {
      "type": "boolean",
      "default": false,
      "uniform": "quantize",
      "ui": { "label": "quantize", "control": "checkbox", "category": "agents" }
    },
    "inputWeight": {
      "type": "float",
      "default": 100,
      "uniform": "inputWeight",
      "min": 0,
      "max": 100,
      "step": 1,
      "ui": { "label": "input weight", "control": "slider", "category": "agents" }
    }
  },
  "uniformLayouts": {
    "agent": {
      "resolution": { "slot": 0, "components": "xy" },
      "time": { "slot": 0, "components": "z" },
      "stride": { "slot": 0, "components": "w" },
      "strideDeviation": { "slot": 1, "components": "x" },
      "kink": { "slot": 1, "components": "y" },
      "quantize": { "slot": 1, "components": "z" },
      "inputWeight": { "slot": 1, "components": "w" },
      "behavior": { "slot": 2, "components": "x" }
    },
    "passthrough": {
      "resolution": { "slot": 0, "components": "xy" }
    }
  },
  "outputXyz": "global_xyz",
  "outputVel": "global_vel",
  "outputRgba": "global_rgba",
  "passes": [
    {
      "name": "agent",
      "program": "agent",
      "drawBuffers": 3,
      "inputs": {
        "xyzTex": "global_xyz",
        "velTex": "global_vel",
        "rgbaTex": "global_rgba",
        "inputTex": "inputTex"
      },
      "uniforms": {
        "behavior": "behavior",
        "stride": "stride",
        "strideDeviation": "strideDeviation",
        "kink": "kink",
        "quantize": "quantize",
        "inputWeight": "inputWeight"
      },
      "outputs": {
        "color": "global_xyz",
        "color1": "global_vel",
        "color2": "global_rgba"
      }
    },
    {
      "name": "passthrough",
      "program": "passthrough",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "color": "outputTex"
      }
    }
  ],
  "textures": {},
  "feedback": {
    "_comment": "Agent-based middleware in a particle pipeline (pointsEmit -> flow -> pointsRender). Flow does NOT create or deposit/scatter agents -- it has NO drawMode 'points' pass. State lives in PERSISTENT 'global_'-prefixed textures created by pointsEmit and SHARED across the pipeline (definition.js textures:{} is EMPTY -- flow does not own them). The runtime scopes them per particle pipeline (global_xyz_<pipelineId>, etc.) and treats them as state surfaces: isStateSurface matches the _xyz/_vel/_rgba suffix, so they persist frame-to-frame WITHOUT an end-of-frame swap (ref 04 §10.7); within-frame writes ping-pong (§10.2). The agent pass is MRT (drawBuffers:3) writing all three in one pass. global_xyz=[x,y,z,alive], global_vel=[vx,vy,rotRand,strideRand], global_rgba=[r,g,b,a]. State format MUST be rgba32f (full float) per reference. No drawMode/count/countUniform/blend/repeat anywhere in this effect. The 'agent' pass renders into the stateSize texture but the `resolution` uniform stays at SCREEN size (ref 04 §10.1).",
    "persistent": ["global_xyz", "global_vel", "global_rgba"],
    "transient": [],
    "ownedByEffect": false,
    "createdBy": "pointsEmit",
    "stateFormat": "rgba32f",
    "stateTextureSpecs": {
      "global_xyz": { "width": { "param": "stateSize" }, "height": { "param": "stateSize" }, "format": "rgba32f" },
      "global_vel": { "width": { "param": "stateSize" }, "height": { "param": "stateSize" }, "format": "rgba32f" },
      "global_rgba": { "width": { "param": "stateSize" }, "height": { "param": "stateSize" }, "format": "rgba32f" }
    },
    "mrt": true,
    "deposit": false
  }
}

{
  "name": "Split",
  "namespace": "mixer",
  "func": "split",
  "tags": ["blend"],
  "description": "Split/wipe between two inputs",
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "invert": {
      "type": "int",
      "default": 0,
      "uniform": "invert",
      "choices": {
        "off": 0,
        "on": 1
      }
    },
    "position": {
      "type": "float",
      "default": 0.0,
      "uniform": "position",
      "min": -1,
      "max": 1
    },
    "rotation": {
      "type": "float",
      "default": 0.0,
      "uniform": "rotation",
      "min": -180,
      "max": 180
    },
    "softness": {
      "type": "float",
      "default": 0.0,
      "uniform": "softness",
      "min": 0,
      "max": 1
    },
    "speed": {
      "type": "int",
      "default": 0,
      "uniform": "speed",
      "min": 0,
      "max": 4
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "split",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {}
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

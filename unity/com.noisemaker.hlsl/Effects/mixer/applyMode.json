{
  "name": "ApplyMode",
  "namespace": "mixer",
  "func": "applyMode",
  "tags": ["color"],
  "description": "Apply brightness, hue, or saturation from source B to source A",
  "paramAliases": {
    "mixAmt": "mix"
  },
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "mode": {
      "type": "int",
      "default": 0,
      "uniform": "mode",
      "choices": {
        "brightness": 0,
        "hue": 1,
        "saturation": 2
      }
    },
    "mix": {
      "type": "float",
      "default": 0,
      "uniform": "mixAmt",
      "min": -100,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "applyMode",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "mixAmt": "mix"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "BlendMode",
  "namespace": "mixer",
  "func": "blendMode",
  "tags": ["color"],
  "description": "Blend two inputs using selectable blend mode",
  "paramAliases": {
    "mixAmt": "mix"
  },
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "mode": {
      "type": "int",
      "default": 0,
      "uniform": "mode",
      "choices": {
        "add": 0,
        "burn": 1,
        "darken": 2,
        "diff": 3,
        "dodge": 4,
        "exclusion": 5,
        "hardLight": 6,
        "lighten": 7,
        "mix": 8,
        "multiply": 9,
        "negation": 10,
        "overlay": 11,
        "phoenix": 12,
        "screen": 13,
        "softLight": 14,
        "subtract": 15
      }
    },
    "mix": {
      "type": "float",
      "default": 0,
      "uniform": "mixAmt",
      "min": -100,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "blendMode",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "mixAmt": "mix"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

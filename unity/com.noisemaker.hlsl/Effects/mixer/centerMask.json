{
  "name": "CenterMask",
  "namespace": "mixer",
  "func": "centerMask",
  "tags": ["blend"],
  "description": "Blend from edges (A) into center (B) using a distance mask",
  "paramAliases": {
    "mixAmt": "mix"
  },
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "blendMode": {
      "type": "int",
      "default": 8,
      "uniform": "blendMode",
      "choices": {
        "add": 0,
        "burn": 1,
        "darken": 2,
        "diff": 3,
        "dodge": 4,
        "exclusion": 5,
        "hardLight": 6,
        "lighten": 7,
        "mix": 8,
        "multiply": 9,
        "negation": 10,
        "overlay": 11,
        "phoenix": 12,
        "screen": 13,
        "softLight": 14,
        "subtract": 15
      }
    },
    "shape": {
      "type": "int",
      "default": 2,
      "uniform": "shape",
      "choices": {
        "circle": 0,
        "diamond": 1,
        "square": 2
      }
    },
    "hardness": {
      "type": "float",
      "default": 0,
      "uniform": "hardness",
      "min": 0,
      "max": 100
    },
    "mix": {
      "type": "float",
      "default": 0,
      "uniform": "power",
      "min": -100,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "centerMask",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "shape": "shape",
        "power": "mix"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "PatternMix",
  "namespace": "mixer",
  "func": "patternMix",
  "tags": ["blend", "pattern"],
  "description": "Mix inputs using geometric patterns",
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "invert": {
      "type": "int",
      "default": 0,
      "uniform": "invert",
      "choices": {
        "sourceA": 1,
        "sourceB": 0
      }
    },
    "type": {
      "type": "int",
      "default": 7,
      "uniform": "patternType",
      "choices": {
        "checkerboard": 0,
        "concentricRings": 1,
        "dots": 2,
        "grid": 3,
        "hexagons": 4,
        "radialLines": 5,
        "spiral": 6,
        "stripes": 7,
        "triangularGrid": 8
      }
    },
    "scale": {
      "type": "float",
      "default": 18.0,
      "uniform": "scale",
      "min": 1,
      "max": 20
    },
    "thickness": {
      "type": "float",
      "default": 0.5,
      "uniform": "thickness",
      "min": 0,
      "max": 1
    },
    "smoothness": {
      "type": "float",
      "default": 0.01,
      "uniform": "smoothness",
      "min": 0,
      "max": 0.25
    },
    "rotation": {
      "type": "float",
      "default": 0.0,
      "uniform": "rotation",
      "min": -180,
      "max": 180
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "patternMix",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {}
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

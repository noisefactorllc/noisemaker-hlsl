{
  "name": "CellSplit",
  "namespace": "mixer",
  "func": "cellSplit",
  "tags": ["blend", "noise"],
  "description": "Split between inputs using Voronoi cell regions",
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "invert": {
      "type": "int",
      "default": 0,
      "uniform": "invert",
      "choices": {
        "sourceA": 0,
        "sourceB": 1
      }
    },
    "mode": {
      "type": "int",
      "default": 0,
      "uniform": "mode",
      "choices": {
        "edges": 0,
        "split": 1
      }
    },
    "scale": {
      "type": "float",
      "default": 15.0,
      "uniform": "scale",
      "min": 1,
      "max": 30
    },
    "edgeWidth": {
      "type": "float",
      "default": 0.08,
      "uniform": "edgeWidth",
      "min": 0,
      "max": 0.2
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": 0,
      "max": 5
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "cellSplit",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {}
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "Alpha Mask",
  "namespace": "mixer",
  "func": "alphaMask",
  "tags": ["blend"],
  "description": "Alpha transparency blend",
  "paramAliases": {
    "mixAmt": "mix"
  },
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "mix": {
      "type": "float",
      "default": 0,
      "uniform": "mixAmt",
      "min": -100,
      "max": 100
    },
    "maskMode": {
      "type": "boolean",
      "default": false,
      "uniform": "maskMode"
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "alphaMask",
      "inputs": {
        "inputTex": "inputTex",
        "tex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "mixAmt": "mix",
        "maskMode": "maskMode"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

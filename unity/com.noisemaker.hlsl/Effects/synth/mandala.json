    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": -5,
      "max": 5
    },
    "pulseDepth": {
      "type": "float",
      "default": 0.15,
      "uniform": "pulseDepth",
      "min": 0.0,
      "max": 1.0
    }

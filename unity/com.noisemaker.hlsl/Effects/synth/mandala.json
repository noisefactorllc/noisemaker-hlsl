{
  "name": "Mandala",
  "namespace": "synth",
  "func": "mandala",
  "tags": ["geometric", "pattern"],
  "description": "N-fold symmetric mandala generator",
  "paramAliases": {},
  "globals": {
    "scale": {
      "type": "float",
      "default": 10.0,
      "uniform": "scale",
      "min": 1.0,
      "max": 20.0
    },
    "rotation": {
      "type": "float",
      "default": 0.0,
      "uniform": "rotation",
      "min": -180.0,
      "max": 180.0
    },
    "thickness": {
      "type": "float",
      "default": 0.2,
      "uniform": "thickness",
      "min": 0.0,
      "max": 1.0
    },
    "smoothness": {
      "type": "float",
      "default": 0.02,
      "uniform": "smoothness",
      "min": 0.0,
      "max": 1.0
    },
    "symmetry": {
      "type": "int",
      "default": 12,
      "uniform": "symmetry",
      "min": 3,
      "max": 24
    },
    "bindu": {
      "type": "boolean",
      "default": false,
      "uniform": "bindu"
    },
    "shape": {
      "type": "int",
      "default": 0,
      "uniform": "shape",
      "choices": {
        "dot": 2,
        "petal": 0,
        "triangle": 1
      }
    },
    "layers": {
      "type": "int",
      "default": 6,
      "uniform": "layers",
      "min": 1,
      "max": 12
    },
    "layerSpacing": {
      "type": "float",
      "default": 1.5,
      "uniform": "layerSpacing",
      "min": 0.5,
      "max": 3.0
    },
    "twist": {
      "type": "float",
      "default": 0.0,
      "uniform": "twist",
      "min": -45.0,
      "max": 45.0
    },
    "shapeGrowth": {
      "type": "float",
      "default": 0.0,
      "uniform": "shapeGrowth",
      "min": -1.0,
      "max": 1.0
    },
    "fgColor": {
      "type": "color",
      "default": [1.0, 1.0, 1.0],

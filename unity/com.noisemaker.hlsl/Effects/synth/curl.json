      "max": 1000
    },
    "ridges": {
      "type": "boolean",
      "default": true,
      "uniform": "ridges",
      "define": "RIDGES"
    },
    "intensity": {
      "type": "float",
      "default": 1.0,
      "uniform": "intensity",
      "min": 0,
      "max": 2
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": 0,
      "max": 5

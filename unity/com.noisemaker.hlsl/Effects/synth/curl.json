{
  "name": "Curl",
  "namespace": "synth",
  "func": "curl",
  "tags": ["noise"],
  "description": "3D curl noise using simplex noise",
  "paramAliases": {},
  "globals": {
    "scale": {
      "type": "float",
      "default": 16,
      "uniform": "scale",
      "min": 0.5,
      "max": 20
    },
    "octaves": {
      "type": "int",
      "default": 1,
      "uniform": "octaves",
      "define": "OCTAVES",
      "min": 1,
      "max": 3
    },
    "seed": {
      "type": "int",
      "default": 0,

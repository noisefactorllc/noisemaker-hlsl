{
  "name": "Mnca",
  "namespace": "synth",
  "func": "mnca",
  "tags": ["sim"],
  "description": "Multi-neighborhood cellular automata",
  "paramAliases": {},
  "globals": {
    "tex": {
      "type": "surface",
      "default": "none"
    },
    "zoom": {
      "type": "int",
      "default": 8,
      "choices": { "x1": 1, "x2": 2, "x4": 4, "x8": 8, "x16": 16, "x32": 32, "x64": 64 },
      "randChoices": [4, 8, 16, 32, 64]
    },
    "seed": {
      "type": "int",
      "default": 1,
      "min": 1,
      "max": 100,
      "uniform": "seed"
    },
    "smoothing": {
      "type": "int",
      "default": 0,
      "choices": {
        "constant": 0,
        "linear": 1,
        "hermite": 2,
        "catmullRom3x3": 3,
        "catmullRom4x4": 4,
        "bSpline3x3": 5,
        "bSpline4x4": 6
      },
      "uniform": "smoothing"
    },
    "speed": {
      "type": "float",
      "default": 10,
      "min": 1,
      "max": 100,
      "uniform": "speed"
    },
    "resetState": {
      "type": "boolean",
      "default": false,
      "uniform": "resetState"
    },
    "weight": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 100,
      "randChance": 0,
      "uniform": "weight"
    },
    "n1v1": { "type": "float", "default": 21, "min": 0, "max": 100, "randMin": 20, "uniform": "n1v1" },
    "n1r1": { "type": "float", "default": 1,  "min": 0, "max": 100, "uniform": "n1r1" },
    "n1v2": { "type": "float", "default": 35, "min": 0, "max": 100, "randMin": 20, "uniform": "n1v2" },
    "n1r2": { "type": "float", "default": 15, "min": 0, "max": 100, "uniform": "n1r2" },
    "n1v3": { "type": "float", "default": 75, "min": 0, "max": 100, "randMin": 20, "uniform": "n1v3" },
    "n1r3": { "type": "float", "default": 10, "min": 0, "max": 100, "uniform": "n1r3" },
    "n1v4": { "type": "float", "default": 12, "min": 0, "max": 100, "randMin": 20, "uniform": "n1v4" },
    "n1r4": { "type": "float", "default": 3,  "min": 0, "max": 100, "uniform": "n1r4" },
    "n2v1": { "type": "float", "default": 10, "min": 0, "max": 100, "randMin": 20, "uniform": "n2v1" },
    "n2r1": { "type": "float", "default": 18, "min": 0, "max": 100, "uniform": "n2r1" },
    "n2v2": { "type": "float", "default": 43, "min": 0, "max": 100, "randMin": 20, "uniform": "n2v2" },
    "n2r2": { "type": "float", "default": 12, "min": 0, "max": 100, "uniform": "n2r2" },
    "source": {
      "type": "int",
      "default": 0,
      "min": 0,
      "max": 7,
      "uniform": "source"
    }
  },
  "passes": [
    {
      "name": "update",
      "program": "mncaFb",
      "inputs": {
        "bufTex": "global_mnca_state",
        "seedTex": "tex"
      },
      "outputs": {
        "fragColor": "global_mnca_state"
      }
    },
    {
      "name": "render",
      "program": "mnca",
      "inputs": {
        "fbTex": "global_mnca_state",
        "prevFrameTex": "global_mnca_state",
        "bufTex": "global_mnca_state",
        "seedTex": "tex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "global_mnca_state": {
      "width": { "screenDivide": "zoom", "default": 8 },
      "height": { "screenDivide": "zoom", "default": 8 },
      "format": "rgba16f"
    }
  }
}

{
  "name": "Octave Warp",
  "namespace": "filter",
  "func": "octaveWarp",
  "tags": ["distort"],
  "description": "Per-octave noise warp distortion",
  "paramAliases": { "frequency": "freq" },
  "globals": {
    "freq": {
      "type": "float",
      "default": 2,
      "uniform": "frequency",
      "min": 1,
      "max": 10,
      "step": 0.1
    },
    "octaves": {
      "type": "int",
      "default": 3,
      "uniform": "octaves",
      "min": 1,
      "max": 5,
      "step": 1
    },
    "displacement": {
      "type": "float",
      "default": 0.2,
      "uniform": "displacement",
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": 0,
      "max": 5
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    },
    "wrap": {
      "type": "int",
      "default": 0,
      "uniform": "wrap",
      "choices": { "mirror": 0, "repeat": 1, "clamp": 2 }
    },
    "antialias": {
      "type": "boolean",
      "default": true,
      "uniform": "antialias"
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "octaveWarp",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "frequency": "frequency",
        "octaves": "octaves",
        "displacement": "displacement",
        "speed": "speed",
        "seed": "seed",
        "wrap": "wrap",
        "antialias": "antialias"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "Scratches",
  "namespace": "filter",
  "func": "scratches",
  "tags": ["noise"],
  "description": "Film scratch overlay",
  "paramAliases": {},
  "globals": {
    "density": {
      "type": "float",
      "default": 0.3,
      "uniform": "density",
      "min": 0,
      "max": 1
    },
    "alpha": {
      "type": "float",
      "default": 0.75,
      "uniform": "alpha",
      "min": 0,
      "max": 1
    },
    "seed": {
      "type": "int",
      "default": 1,
      "uniform": "seed",
      "min": 1,
      "max": 100
    }
  },
  "passes": [
    {
      "name": "blend",
      "program": "scratchesBlend",
      "inputs": {
        "inputTex": "inputTex",
        "overlayTex": "overlayTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "alpha": "alpha"
      }
    }
  ],
  "textures": {
    "overlayTex": {
      "width": "screen",
      "height": "screen",
      "format": "rgba8",
      "note": "CPU-generated by asyncInit (traceWorms); runtime must populate before first render pass."
    },
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

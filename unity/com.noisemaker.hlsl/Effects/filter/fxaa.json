{
  "name": "Fxaa",
  "namespace": "filter",
  "func": "fxaa",
  "tags": ["antialiasing"],
  "description": "Fast approximate anti-aliasing",
  "paramAliases": {},
  "globals": {
    "strength": {
      "type": "float",
      "default": 1.0,
      "min": 0,
      "max": 1,
      "uniform": "strength"
    },
    "sharpness": {
      "type": "float",
      "default": 1.0,
      "min": 0.1,
      "max": 10,
      "uniform": "sharpness"
    },
    "threshold": {
      "type": "float",
      "default": 0.0,
      "min": 0,
      "max": 1,
      "uniform": "threshold"
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "fxaa",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "strength": 1.0,
        "sharpness": 1.0,
        "threshold": 0.0
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "Rotate",
  "namespace": "filter",
  "func": "rotate",
  "tags": ["transform"],
  "description": "Rotate image by specified angle",
  "paramAliases": {},
  "globals": {
    "rotation": {
      "type": "float",
      "default": 45,
      "uniform": "rotation",
      "min": -180,
      "max": 180,
      "step": 0.01,
      "zero": 0
    },
    "wrap": {
      "type": "int",
      "default": 1,
      "uniform": "wrap",
      "choices": {
        "mirror": 0,
        "repeat": 1,
        "clamp": 2
      }
    },
    "speed": {
      "type": "int",
      "default": 0,
      "uniform": "speed",
      "min": -4,
      "max": 4,
      "zero": 0,
      "randMin": -2,
      "randMax": 2
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "rot",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "rotation": 45,
        "wrap": 1,
        "speed": 0
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

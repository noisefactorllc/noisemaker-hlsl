{
  "name": "Tint",
  "namespace": "filter",
  "func": "tint",
  "tags": ["color"],
  "description": "Colorize input texture with a color overlay",
  "paramAliases": {},
  "globals": {
    "color": {
      "type": "color",
      "default": [1.0, 1.0, 1.0],
      "uniform": "color"
    },
    "alpha": {
      "type": "float",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "randMin": 0.5,
      "uniform": "alpha"
    },
    "mode": {
      "type": "int",
      "default": 0,
      "uniform": "mode",
      "choices": {
        "overlay": 0,
        "multiply": 1,
        "recolor": 2
      }
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "colorize",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "color": "outputTex"
      },
      "uniforms": {
        "color": [1.0, 1.0, 1.0],
        "alpha": 0.5,
        "mode": 0
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

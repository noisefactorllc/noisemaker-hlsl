{
  "name": "Posterize",
  "namespace": "filter",
  "func": "posterize",
  "tags": ["color"],
  "description": "Posterization/color reduction with gamma control",
  "paramAliases": {},
  "globals": {
    "levels": {
      "type": "int",
      "default": 5,
      "uniform": "levels",
      "min": 2,
      "max": 32,
      "step": 1
    },
    "gamma": {
      "type": "float",
      "default": 1,
      "uniform": "gamma",
      "min": 0.1,
      "max": 3,
      "step": 0.05
    },
    "antialias": {
      "type": "boolean",
      "default": true,
      "uniform": "antialias"
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "posterize",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "levels": "levels",
        "gamma": "gamma",
        "antialias": "antialias"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

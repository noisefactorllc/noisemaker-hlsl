{
  "name": "Tunnel",
  "namespace": "filter",
  "func": "tunnel",
  "tags": ["distort"],
  "description": "Perspective tunnel effect with shape options",
  "paramAliases": {},
  "globals": {
    "shape": {
      "type": "int",
      "default": 0,
      "uniform": "shape",
      "choices": {
        "circle": 0,
        "triangle": 1,
        "roundedRect": 2,
        "square": 3,
        "hexagon": 4,
        "octagon": 5
      }
    },
    "scale": {
      "type": "float",
      "default": 0,
      "uniform": "scale",
      "min": -1,
      "max": 1,
      "step": 0.1
    },
    "speed": {
      "type": "int",
      "default": 1,
      "uniform": "speed",
      "min": -5,
      "max": 5
    },
    "rotation": {
      "type": "int",
      "default": 0,
      "uniform": "rotation",
      "min": -2,
      "max": 2
    },
    "center": {
      "type": "float",
      "default": 100,
      "uniform": "center",
      "min": -100,
      "max": 100
    },
    "aspectLens": {
      "type": "boolean",
      "default": true,
      "uniform": "aspectLens"
    },
    "antialias": {
      "type": "boolean",
      "default": true,
      "uniform": "antialias"
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "tunnel",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "shape": "shape",
        "scale": "scale",
        "speed": "speed",
        "rotation": "rotation",
        "center": "center",
        "aspectLens": "aspectLens",
        "antialias": "antialias"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

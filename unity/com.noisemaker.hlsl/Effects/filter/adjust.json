{
  "name": "Adjust",
  "namespace": "filter",
  "func": "adjust",
  "tags": ["color"],
  "description": "Colorspace, hue/saturation, brightness/contrast",
  "paramAliases": {},
  "globals": {
    "mode": {
      "type": "int",
      "default": 0,
      "uniform": "mode",
      "choices": {
        "rgb": 0,
        "hsv": 1,
        "oklab": 2,
        "oklch": 3
      }
    },
    "rotation": {
      "type": "float",
      "default": 0,
      "uniform": "rotation",
      "min": -180,
      "max": 180
    },
    "hueRange": {
      "type": "float",
      "default": 100,
      "uniform": "hueRange",
      "min": 0,
      "max": 200
    },
    "saturation": {
      "type": "float",
      "default": 1,
      "uniform": "saturation",
      "min": 0,
      "max": 4
    },
    "brightness": {
      "type": "float",
      "default": 1,
      "uniform": "brightness",
      "min": 0,
      "max": 10
    },
    "contrast": {
      "type": "float",
      "default": 0.5,
      "uniform": "contrast",
      "min": 0,
      "max": 1
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "adjust",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {}
    }
  ],
  "textures": {
    "outputTex": { "width": "input", "height": "input", "format": "rgba16f" }
  }
}

{
  "name": "Tile",
  "namespace": "filter",
  "func": "tile",
  "tags": ["tiling", "transform"],
  "description": "Symmetry-based kaleidoscope tiler",
  "paramAliases": {},
  "globals": {
    "symmetry": {
      "type": "int",
      "default": 0,
      "uniform": "symmetry",
      "choices": {
        "mirrorXY": 0,
        "rotate2": 1,
        "rotate4": 2,
        "rotate6": 3
      }
    },
    "scale": {
      "type": "float",
      "default": 1.0,
      "uniform": "scale",
      "min": 0.1,
      "max": 4.0,
      "step": 0.05
    },
    "offsetX": {
      "type": "float",
      "default": 0.0,
      "uniform": "offsetX",
      "min": -1.0,
      "max": 1.0,
      "step": 0.01
    },
    "offsetY": {
      "type": "float",
      "default": 0.0,
      "uniform": "offsetY",
      "min": -1.0,
      "max": 1.0,
      "step": 0.01
    },
    "angle": {
      "type": "float",
      "default": 0.0,
      "uniform": "angle",
      "min": 0.0,
      "max": 360.0,
      "step": 1.0
    },
    "repeat": {
      "type": "float",
      "default": 2.0,
      "uniform": "repeat",
      "min": 1.0,
      "max": 10.0,
      "step": 1.0
    },
    "aspectLens": {
      "type": "boolean",
      "default": true,
      "uniform": "aspectLens"
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "tile",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "symmetry": "symmetry",
        "scale": "scale",
        "offsetX": "offsetX",
        "offsetY": "offsetY",
        "angle": "angle",
        "repeat": "repeat",
        "aspectLens": "aspectLens"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "Sobel",
  "namespace": "filter",
  "func": "sobel",
  "tags": ["edges"],
  "description": "Classic Sobel edge detection",
  "paramAliases": {},
  "globals": {
    "amount": {
      "type": "float",
      "default": 1.0,
      "uniform": "amount",
      "min": 0.1,
      "max": 5
    },
    "alpha": {
      "type": "float",
      "default": 1.0,
      "uniform": "alpha",
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "sobel",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "amount": 1.0,
        "alpha": 1.0
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }

{
  "name": "Texture",
  "namespace": "filter",
  "func": "texture",
  "tags": ["noise"],
  "description": "Texture overlay blend",
  "paramAliases": {},
  "globals": {
    "mode": {
      "type": "int",
      "default": 3,
      "uniform": "mode",
      "define": "MODE",
      "choices": {
        "canvas": 0,
        "crosshatch": 1,
        "halftone": 2,
        "paper": 3,
        "stucco": 4
      }
    },
    "alpha": {
      "type": "float",
      "default": 0.5,
      "uniform": "alpha",
      "min": 0,
      "max": 1,
      "step": 0.01
    },
    "scale": {
      "type": "float",
      "default": 1.0,
      "uniform": "scale",
      "min": 0.1,
      "max": 10,
      "step": 0.1
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "texture",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "mode": 3,
        "alpha": 0.5,
        "scale": 1.0
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

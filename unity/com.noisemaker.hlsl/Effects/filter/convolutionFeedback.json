{
  "name": "Convolution Feedback",
  "namespace": "filter",
  "func": "convolutionFeedback",
  "tags": ["sim"],
  "description": "Convolution feedback with blur and sharpen",
  "paramAliases": {},
  "globals": {
    "sharpenRadius": {
      "type": "int",
      "default": 5,
      "uniform": "sharpenRadius",
      "min": 1,
      "max": 10,
      "step": 1,
      "randMin": 4
    },
    "sharpenAmount": {
      "type": "float",
      "default": 2.5,
      "uniform": "sharpenAmount",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "randMin": 1
    },
    "blurRadius": {
      "type": "int",
      "default": 4,
      "uniform": "blurRadius",
      "min": 1,
      "max": 10,
      "step": 1,
      "randMax": 4
    },
    "blurAmount": {
      "type": "float",
      "default": 0.5,
      "uniform": "blurAmount",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "randMax": 0.3
    },
    "intensity": {
      "type": "float",
      "default": 0.75,
      "uniform": "intensity",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "zero": 0,
      "randMin": 0.65
    },
    "resetState": {
      "type": "boolean",
      "default": false,
      "uniform": "resetState"
    }
  },
  "passes": [
    {
      "name": "sharpen",
      "program": "cfSharpen",
      "inputs": {
        "inputTex": "selfTex"
      },
      "outputs": {
        "fragColor": "_cfSharpened"
      }
    },
    {
      "name": "blur",
      "program": "cfBlur",
      "inputs": {
        "inputTex": "_cfSharpened"
      },
      "outputs": {
        "fragColor": "_cfBlurred"
      }
    },
    {
      "name": "blend",
      "program": "cfBlend",
      "inputs": {
        "inputTex": "inputTex",
        "feedbackTex": "_cfBlurred"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "_cfSharpened": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm",
      "_role": "transient internal (pooled); sharpen result"
    },
    "_cfBlurred": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm",
      "_role": "transient internal (pooled); blur result, blend feedback source"
    }
  },
  "feedback": {
    "_comment": "Pass 0 input 'selfTex' is the canonical feedback alias (expander 03 reference 5.1 #7). At expand time it resolves to the chain's write surface, double-buffered (feedback_<outName> when plan.write.kind=='feedback', else global_<outName>). The runtime renders cfBlend into the write buffer; the next frame's cfSharpen reads the prior frame's read buffer. resetState bypasses feedback in cfBlend. No '_iteration' uniform; no repeat; no MRT.",
    "input": "selfTex"
  }
}

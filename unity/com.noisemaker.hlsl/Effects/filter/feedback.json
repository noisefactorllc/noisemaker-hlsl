{
  "name": "Feedback",
  "namespace": "filter",
  "func": "feedback",
  "tags": ["sim"],
  "description": "Feedback loop with blend modes and transforms",
  "paramAliases": {
    "mixAmt": "mix",
    "aberrationAmt": "aberration"
  },
  "globals": {
    "blendMode": {
      "type": "int",
      "default": 10,
      "uniform": "blendMode",
      "choices": {
        "add": 0,
        "cloak": 100,
        "colorBurn": 2,
        "colorDodge": 3,
        "darken": 4,
        "difference": 5,
        "exclusion": 6,
        "glow": 7,
        "hardLight": 8,
        "lighten": 9,
        "mix": 10,
        "multiply": 11,
        "negation": 12,
        "overlay": 13,
        "phoenix": 14,
        "reflect": 15,
        "screen": 16,
        "softLight": 17,
        "subtract": 18
      }
    },
    "mix": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 100,
      "randMax": 25,
      "uniform": "mixAmt"
    },
    "scaleAmt": {
      "type": "float",
      "default": 100,
      "min": 75,
      "max": 200,
      "uniform": "scaleAmt"
    },
    "rotation": {
      "type": "float",
      "default": 0,
      "min": -180,
      "max": 180,
      "uniform": "rotation"
    },
    "refractAAmt": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 100,
      "uniform": "refractAAmt"
    },
    "refractBAmt": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 100,
      "uniform": "refractBAmt"
    },
    "refractADir": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 360,
      "uniform": "refractADir"
    },
    "refractBDir": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 360,
      "uniform": "refractBDir"
    },
    "hueRotation": {
      "type": "float",
      "default": 0,
      "min": -180,
      "max": 180,
      "uniform": "hueRotation"
    },
    "intensity": {
      "type": "float",
      "default": 0,
      "min": -100,
      "max": 100,
      "uniform": "intensity"
    },
    "aberration": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 100,
      "uniform": "aberration"
    },
    "distortion": {
      "type": "float",
      "default": 0,
      "min": -100,
      "max": 100,
      "uniform": "distortion"
    },
    "resetState": {
      "type": "boolean",
      "default": false,
      "uniform": "resetState"
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "feedback",
      "inputs": {
        "inputTex": "inputTex",
        "selfTex": "_selfTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    },
    {
      "name": "feedback",
      "program": "copy",
      "inputs": {
        "inputTex": "outputTex"
      },
      "outputs": {
        "fragColor": "_selfTex"
      }
    }
  ],
  "textures": {
    "_selfTex": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    },
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

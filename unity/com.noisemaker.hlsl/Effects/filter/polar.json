{
  "name": "Polar",
  "namespace": "filter",
  "func": "polar",
  "tags": ["distort"],
  "description": "Polar and vortex coordinate transforms",
  "paramAliases": {},
  "globals": {
    "mode": {
      "type": "int",
      "default": 0,
      "uniform": "polarMode",
      "choices": {
        "polar": 0,
        "vortex": 1
      }
    },
    "scale": {
      "type": "float",
      "default": 0,
      "uniform": "scale",
      "min": -2,
      "max": 2,
      "step": 0.1
    },
    "rotation": {
      "type": "int",
      "default": 0,
      "uniform": "rotation",
      "min": -2,
      "max": 2
    },
    "speed": {
      "type": "int",
      "default": 0,
      "uniform": "speed",
      "min": -2,
      "max": 2
    },
    "aspectLens": {
      "type": "boolean",
      "default": true,
      "uniform": "aspectLens"
    },
    "antialias": {
      "type": "boolean",
      "default": true,
      "uniform": "antialias"
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "polar",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "polarMode": "mode",
        "scale": "scale",
        "rotation": "rotation",
        "speed": "speed",
        "aspectLens": "aspectLens",
        "antialias": "antialias"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

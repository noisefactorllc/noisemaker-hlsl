{
  "name": "Translate",
  "namespace": "filter",
  "func": "translate",
  "tags": ["transform"],
  "description": "Translate image in X and Y",
  "paramAliases": {},
  "globals": {
    "x": {
      "type": "float",
      "default": 0,
      "uniform": "x",
      "min": -1,
      "max": 1,
      "step": 0.01
    },
    "y": {
      "type": "float",
      "default": 0,
      "uniform": "y",
      "min": -1,
      "max": 1,
      "step": 0.01
    },
    "wrap": {
      "type": "int",
      "default": 1,
      "uniform": "wrap",
      "choices": {
        "mirror": 0,
        "repeat": 1,
        "clamp": 2
      }
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "translate",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "x": "x",
        "y": "y",
        "wrap": "wrap"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "Lens",
  "namespace": "filter",
  "func": "lens",
  "tags": ["distort", "lens"],
  "description": "Barrel or pincushion lens distortion",
  "paramAliases": {},
  "globals": {
    "displacement": {
      "type": "float",
      "default": 0,
      "uniform": "lensDisplacement",
      "min": -1,
      "max": 1,
      "step": 0.01
    },
    "aspectLens": {
      "type": "boolean",
      "default": true,
      "uniform": "aspectLens"
    },
    "antialias": {
      "type": "boolean",
      "default": true,
      "uniform": "antialias"
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "lens",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "lensDisplacement": "displacement",
        "aspectLens": "aspectLens",
        "antialias": "antialias"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "PrismaticAberration",
  "namespace": "filter",
  "func": "prismaticAberration",
  "tags": ["color", "lens"],
  "description": "Prismatic aberration with hue controls",
  "paramAliases": { "aberrationAmt": "aberration" },
  "globals": {
    "aberration": {
      "type": "float",
      "default": 50,
      "min": 0,
      "max": 100,
      "uniform": "aberrationAmt"
    },
    "modulate": {
      "type": "boolean",
      "default": false,
      "uniform": "modulate"
    },
    "hueRotation": {
      "type": "float",
      "default": 0,
      "min": -180,
      "max": 180,
      "uniform": "hueRotation"
    },
    "hueRange": {
      "type": "float",
      "default": 0,
      "min": 0,
      "max": 100,
      "uniform": "hueRange"
    },
    "saturation": {
      "type": "float",
      "default": 0,
      "min": -100,
      "max": 100,
      "uniform": "saturation"
    },
    "passthru": {
      "type": "float",
      "default": 50,
      "min": 0,
      "max": 100,
      "uniform": "passthru"
    }
  },
  "passes": [
    {
      "name": "render",
      "program": "prismaticAberration",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "aberrationAmt": 50,
        "modulate": 0,
        "hueRotation": 0,
        "hueRange": 0,
        "saturation": 0,
        "passthru": 50
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }

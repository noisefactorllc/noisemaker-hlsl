{
  "name": "Smooth",
  "namespace": "filter",
  "func": "smooth",
  "tags": ["antialiasing"],
  "description": "Anti-aliasing with MSAA, SMAA, or edge-selective blur modes",
  "paramAliases": {},
  "globals": {
    "type": {
      "type": "int",
      "default": 0,
      "uniform": "smoothType",
      "choices": { "msaa": 0, "smaa": 1, "blur": 2 }
    },
    "strength": {
      "type": "float",
      "default": 1.0,
      "uniform": "strength",
      "min": 0,
      "max": 1,
      "zero": 0
    },
    "threshold": {
      "type": "float",
      "default": 0.1,
      "uniform": "threshold",
      "min": 0,
      "max": 1
    },
    "radius": {
      "type": "float",
      "default": 2.0,
      "uniform": "radius",
      "min": 0.5,
      "max": 4,
      "step": 0.1
    },
    "samples": {
      "type": "int",
      "default": 4,
      "uniform": "samples",
      "choices": { "x2": 2, "x4": 4, "x8": 8 }
    },
    "searchSteps": {
      "type": "int",
      "default": 8,
      "uniform": "searchSteps",
      "min": 1,
      "max": 32,
      "step": 1
    }
  },
  "passes": [
    {
      "name": "smoothEdge",
      "program": "smoothEdge",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "_smoothEdges"
      },
      "uniforms": {
        "smoothType": "smoothType",
        "threshold": "threshold"
      }
    },
    {
      "name": "smoothBlend",
      "program": "smoothBlend",
      "inputs": {
        "inputTex": "inputTex",
        "edgeTex": "_smoothEdges"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "smoothType": "smoothType",
        "strength": "strength",
        "threshold": "threshold",
        "radius": "radius",
        "samples": "samples",
        "searchSteps": "searchSteps"
      }
    }
  ],
  "textures": {
    "_smoothEdges": {
      "width": "input",
      "height": "input",
      "format": "rgba8unorm"
    },
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "Seamless",
  "namespace": "filter",
  "func": "seamless",
  "tags": ["tiling", "transform"],
  "description": "Edge-blend cross-fade for seamless tiling",
  "paramAliases": {},
  "globals": {
    "blend": {
      "type": "float",
      "default": 0.25,
      "min": 0.0,
      "max": 0.5,
      "uniform": "blend"
    },
    "repeat": {
      "type": "float",
      "default": 2.0,
      "min": 1.0,
      "max": 10.0,
      "uniform": "repeat"
    },
    "curve": {
      "type": "int",
      "default": 1,
      "uniform": "curve",
      "choices": {
        "linear": 0,
        "smooth": 1,
        "sharp": 2
      }
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "seamless",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "blend": "blend",
        "repeat": "repeat",
        "curve": "curve"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

{
  "name": "Glowing Edge",
  "namespace": "filter",
  "func": "glowingEdge",
  "tags": ["edges"],
  "description": "Glowing edge detection",
  "paramAliases": {},
  "globals": {
    "shape": {
      "type": "int",
      "default": 0,
      "uniform": "sobelMetric",
      "choices": {
        "circle": 0,
        "diamond": 1,
        "square": 2,
        "star": 3
      }
    },
    "width": {
      "type": "int",
      "default": 1,
      "uniform": "width",
      "min": 0,
      "max": 10
    },
    "alpha": {
      "type": "float",
      "default": 1,
      "uniform": "alpha",
      "min": 0,
      "max": 1,
      "step": 0.05
    }
  },
  "passes": [
    {
      "name": "main",
      "program": "glowingEdge",
      "inputs": {
        "inputTex": "inputTex"
      },
      "outputs": {
        "fragColor": "outputTex"
      },
      "uniforms": {
        "sobelMetric": "shape",
        "alpha": "alpha",
        "width": "width"
      }
    }
  ],
  "textures": {
    "outputTex": {
      "width": "input",
      "height": "input",
      "format": "rgba16f"
    }
  }
}

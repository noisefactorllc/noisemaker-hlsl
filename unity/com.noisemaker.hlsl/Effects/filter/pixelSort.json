{
  "name": "PixelSort",
  "namespace": "filter",
  "func": "pixelSort",
  "tags": ["glitch", "pixel"],
  "description": "Pixel sorting glitch effect",
  "paramAliases": {},
  "globals": {
    "angled": {
      "type": "float",
      "default": 0,
      "uniform": "angled",
      "min": -180,
      "max": 180,
      "step": 1
    },
    "darkest": {
      "type": "boolean",
      "default": false,
      "uniform": "darkest"
    },
    "wrap": {
      "type": "int",
      "default": 0,
      "uniform": "wrap",
      "choices": {
        "mirror": 0,
        "repeat": 1,
        "clamp": 2
      }
    },
    "alpha": {
      "type": "float",
      "default": 1.0,
      "uniform": "alpha",
      "min": 0.0,
      "max": 1.0,
      "step": 0.01
    }
  },
  "passes": [
    {
      "name": "prepare",
      "program": "prepare",
      "inputs": {
        "inputTex": "inputTex"
      },
      "uniforms": {
        "resolution": "resolution",
        "angled": "angled",
        "darkest": "darkest",
        "wrap": "wrap"
      },
      "outputs": {
        "fragColor": "prepared"
      }
    },
    {
      "name": "luminance",
      "program": "luminance",
      "inputs": {
        "inputTex": "prepared"
      },
      "uniforms": {},
      "outputs": {
        "fragColor": "luminance"
      }
    },
    {
      "name": "findBrightest",
      "program": "findBrightest",
      "inputs": {
        "lumTex": "luminance"
      },
      "uniforms": {},
      "outputs": {
        "fragColor": "brightest"
      }
    },
    {
      "name": "computeRank",
      "program": "computeRank",
      "inputs": {
        "lumTex": "luminance"
      },
      "uniforms": {},
      "outputs": {
        "fragColor": "rank"
      }
    },
    {
      "name": "gatherSorted",
      "program": "gatherSorted",
      "inputs": {
        "preparedTex": "prepared",
        "rankTex": "rank",
        "brightestTex": "brightest"
      },
      "uniforms": {},
      "outputs": {
        "fragColor": "sorted"
      }
    },
    {
      "name": "finalize",
      "program": "finalize",
      "inputs": {
        "inputTex": "sorted",
        "originalTex": "inputTex"
      },
      "uniforms": {
        "resolution": "resolution",
        "angled": "angled",
        "darkest": "darkest",
        "wrap": "wrap",
        "alpha": "alpha"
      },
      "outputs": {
        "fragColor": "outputTex"
      }
    }
  ],
  "textures": {
    "prepared":  { "width": "100%", "height": "100%", "format": "rgba16f" },
    "luminance": { "width": "100%", "height": "100%", "format": "rgba16f" },
    "brightest": { "width": "100%", "height": "100%", "format": "rgba16f" },
    "rank":      { "width": "100%", "height": "100%", "format": "rgba16f" },
    "sorted":    { "width": "100%", "height": "100%", "format": "rgba16f" },
    "outputTex": { "width": "input", "height": "input", "format": "rgba16f" }
  }
}
